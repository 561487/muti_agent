# Contelix — AI Competitive Intelligence Platform
# Copy this file to .env and fill in your API keys.

# ── LLM Configuration ──────────────────────────────────────────────────────
# Model name (Qwen, GPT-4o, Claude, etc.)
CONTELIX_MODEL_NAME=qwen2.5-72b-instruct

# Model API base URL
CONTELIX_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model API key (REQUIRED)
CONTELIX_MODEL_API_KEY=sk-your-api-key-here

# Model temperature (0 = deterministic, 1 = creative)
CONTELIX_MODEL_TEMPERATURE=0

# ── Search API Configuration ──────────────────────────────────────────────
# At least one of these is REQUIRED

# BochaAI Search API key (https://open.bochaai.com/)
BOCHA_API_KEY=sk-your-bocha-key

# Tavily Search API key (https://tavily.com/)
TAVILY_API_KEY=tvly-dev-your-tavily-key

# ── Checkpoint / Persistence ───────────────────────────────────────────────
# Backend: memory (default), sqlite, or postgres
CONTELIX_CHECKPOINT_BACKEND=memory
# SQLite DB path (when backend=sqlite)
CONTELIX_CHECKPOINT_DB_PATH=contelix_checkpoints.db

# ── Observability (LangSmith) ──────────────────────────────────────────────
# Enable LangSmith tracing
LANGSMITH_TRACING=false
# LangSmith API key (https://smith.langchain.com/)
LANGSMITH_API_KEY=lsv2-your-langsmith-key
# LangSmith project name
LANGSMITH_PROJECT=contelix
# LangSmith endpoint (usually default)
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Sandbox ────────────────────────────────────────────────────────────────
# Max execution time in seconds for sandboxed Python code
CONTELIX_SANDBOX_TIMEOUT=30

# ── Runtime ────────────────────────────────────────────────────────────────
CONTELIX_MAX_RECURSION=150
CONTELIX_DEBUG=false
CONTELIX_HUMAN_REVIEW=true

# ── Output ─────────────────────────────────────────────────────────────────
CONTELIX_OUTPUT_DIR=./output
